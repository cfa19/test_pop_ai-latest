{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://popskills.ai/schemas/shared/location.json",
  "title": "Location",
  "type": "object",
  "description": "Shared schema for geographic location information",
  "properties": {
    "city": {
      "type": "string",
      "description": "City name",
      "maxLength": 100
    },
    "state_province": {
      "type": "string",
      "description": "State, province, or region",
      "maxLength": 100
    },
    "country": {
      "type": "string",
      "description": "Country name",
      "maxLength": 100
    },
    "country_code": {
      "type": "string",
      "minLength": 2,
      "maxLength": 2,
      "pattern": "^[A-Z]{2}$",
      "description": "ISO 3166-1 alpha-2 country code",
      "examples": ["US", "GB", "CA", "FR", "DE"]
    },
    "timezone": {
      "type": "string",
      "description": "IANA timezone identifier",
      "examples": ["America/New_York", "Europe/London", "Asia/Tokyo"]
    },
    "coordinates": {
      "type": "object",
      "description": "Geographic coordinates",
      "properties": {
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "metro_area": {
      "type": "string",
      "description": "Metropolitan area or region",
      "examples": ["San Francisco Bay Area", "Greater London", "New York Metro"]
    },
    "is_remote": {
      "type": "boolean",
      "description": "Whether this is a remote/virtual location"
    },
    "work_arrangement": {
      "type": "string",
      "enum": ["remote", "hybrid", "on_site", "flexible", "not_applicable"],
      "description": "How work is performed relative to this location"
    },
    "cost_of_living_index": {
      "type": "number",
      "description": "Cost of living index (100 = baseline, e.g., US average)",
      "minimum": 0
    },
    "cost_of_living_category": {
      "type": "string",
      "enum": ["very_low", "low", "moderate", "high", "very_high"],
      "description": "Qualitative cost of living assessment"
    }
  }
}
