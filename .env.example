# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# SUPABASE_JWT_SECRET=your-jwt-secret  # For HS256 local dev
# JWT_ALGORITHM=ES256                   # For JWKS production

# NextJS Frontend (for Harmonia API calls)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# OpenAI Configuration
OPENAI_API_KEY=sk-...
CHAT_MODEL=gpt-4o-mini

# Anthropic (optional, required when CHAT_MODEL starts with "claude")
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI (optional, required when CHAT_MODEL starts with "gemini")
# GOOGLE_API_KEY=...

# Voyage AI Configuration (for embeddings)
VOYAGE_API_KEY=pa-...
EMBED_MODEL=voyage-4-large
EMBED_DIMENSIONS=1024

# Temperature settings
TEMPERATURE_TRANSLATION=0.3
TEMPERATURE_EXTRACTION=0.1
TEMPERATURE_CLASSIFICATION=0.0
TEMPERATURE_RESPONSE=0.3
TEMPERATURE_TASK_RESPONSE=0.5
TEMPERATURE_RECOMMENDATION=0.7

# RAG search parameters
RAG_DOC_TOP_K=3
RAG_CONVERSATION_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.6
PROFILE_RECAP_TOP_K=15
PROFILE_RECAP_SIMILARITY_THRESHOLD=0.3

# LLM limits
MAX_TOKENS=2048
CLIENT_TIMEOUT=30.0

# ONNX token classifier path
ONNX_MODELS_PATH=training/models_onnx

# Semantic Gate Configuration (Stage 1 Filtering)
SEMANTIC_GATE_ENABLED=true
SEMANTIC_GATE_MODEL=all-MiniLM-L6-v2
SEMANTIC_GATE_TUNING_PATH=training/results/semantic_gate_tuning.json
# SEMANTIC_GATE_LOCAL_FILES_ONLY=false
# SEMANTIC_GATE_MODEL_PATH=training/models/sentence_transformers

# Language detection
# LANG_DETECT_FASTTEXT_MODEL_PATH=data/lid.176.bin
LANG_DETECT_ALLOWED_LANGUAGES=en,es,fr
